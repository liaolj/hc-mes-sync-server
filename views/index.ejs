<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>合创 MES 数据同步中心</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', sans-serif;
      background: #f0f2f5;
      color: #2c3e50;
      min-height: 100vh;
    }

    /* 顶部导航 */
    .navbar {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      color: white;
      padding: 16px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    }
    .navbar h1 {
      font-size: 18px;
      font-weight: 600;
      letter-spacing: 1px;
    }
    .navbar .stats {
      display: flex;
      gap: 24px;
      font-size: 13px;
      opacity: 0.85;
    }
    .navbar .stats span { font-weight: 600; color: #4fc3f7; }

    /* 主体 */
    .main { max-width: 1400px; margin: 0 auto; padding: 24px; }

    /* Tab 栏 */
    .tabs {
      display: flex;
      gap: 4px;
      margin-bottom: 20px;
      background: white;
      border-radius: 10px;
      padding: 6px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .tab {
      flex: 1;
      text-align: center;
      padding: 10px 20px;
      border-radius: 8px;
      text-decoration: none;
      color: #666;
      font-weight: 500;
      font-size: 14px;
      transition: all 0.2s;
    }
    .tab:hover { background: #f5f7fa; color: #333; }
    .tab.active {
      background: #3b82f6;
      color: white;
      box-shadow: 0 2px 8px rgba(59,130,246,0.3);
    }

    /* 搜索栏 */
    .search-bar {
      display: flex;
      gap: 12px;
      margin-bottom: 20px;
      align-items: center;
    }
    .search-bar input {
      flex: 1;
      padding: 10px 16px;
      border: 1px solid #dfe6e9;
      border-radius: 8px;
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s;
    }
    .search-bar input:focus { border-color: #3b82f6; }
    .search-bar button {
      padding: 10px 24px;
      background: #3b82f6;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      cursor: pointer;
      font-weight: 500;
      transition: background 0.2s;
    }
    .search-bar button:hover { background: #2563eb; }

    /* 表格 */
    .table-card {
      background: white;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 1px 6px rgba(0, 0, 0, 0.06);
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    thead th {
      background: #f8fafc;
      padding: 12px 14px;
      text-align: left;
      font-weight: 600;
      color: #475569;
      border-bottom: 2px solid #e2e8f0;
      white-space: nowrap;
    }
    tbody td {
      padding: 10px 14px;
      border-bottom: 1px solid #f1f5f9;
      white-space: nowrap;
    }
    tbody tr:hover { background: #f8fafc; }
    .badge-pass {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 12px;
      font-weight: 600;
      background: #dcfce7;
      color: #16a34a;
    }
    .badge-fail {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 12px;
      font-weight: 600;
      background: #fef2f2;
      color: #dc2626;
    }
    .id-cell { color: #94a3b8; font-family: monospace; }
    .barcode-cell { font-weight: 600; font-family: monospace; }
    .file-cell { color: #64748b; font-size: 12px; max-width: 180px; overflow: hidden; text-overflow: ellipsis; }
    .time-cell { color: #94a3b8; font-size: 12px; }
    .client-cell {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 500;
      background: #ede9fe;
      color: #7c3aed;
    }

    /* 分页 */
    .pagination {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 20px;
      font-size: 13px;
      color: #64748b;
      background: white;
      border-top: 1px solid #f1f5f9;
    }
    .pagination a {
      padding: 8px 18px;
      background: #f1f5f9;
      color: #334155;
      text-decoration: none;
      border-radius: 6px;
      font-weight: 500;
      transition: background 0.2s;
    }
    .pagination a:hover { background: #e2e8f0; }
    .pagination a.disabled { opacity: 0.4; pointer-events: none; }
    .page-nav { display: flex; gap: 8px; align-items: center; }

    .empty {
      padding: 60px 20px;
      text-align: center;
      color: #94a3b8;
      font-size: 14px;
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <h1>📡 合创 MES 数据同步中心</h1>
    <div class="stats">
      平坦度数据: <span><%= flatnessTotal %></span> 条 &nbsp;|&nbsp;
      热阻数据: <span><%= thermalTotal %></span> 条
    </div>
  </nav>

  <div class="main">
    <!-- Tab 切换 -->
    <div class="tabs">
      <a class="tab <%= tab === 'flatness' ? 'active' : '' %>" href="/?tab=flatness&token=<%= token %>">
        📐 平坦度数据 (<%= flatnessTotal %>)
      </a>
      <a class="tab <%= tab === 'thermal' ? 'active' : '' %>" href="/?tab=thermal&token=<%= token %>">
        🌡️ 热阻数据 (<%= thermalTotal %>)
      </a>
    </div>

    <!-- 搜索栏 -->
    <form class="search-bar" method="GET" action="/">
      <input type="hidden" name="tab" value="<%= tab %>">
      <input type="hidden" name="token" value="<%= token %>">
      <input type="text" name="search" value="<%= search %>" placeholder="输入条码关键字搜索...">
      <button type="submit">🔍 搜索</button>
    </form>

    <!-- 数据表格 -->
    <div class="table-card">
      <% if (records.length === 0) { %>
        <div class="empty">📭 暂无数据记录</div>
      <% } else if (tab === 'flatness') { %>
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>来源客户端</th>
              <th>条形码</th>
              <th>整体平坦度</th>
              <th>背胶平坦度</th>
              <th>判定结果</th>
              <th>源文件</th>
              <th>采集时间</th>
              <th>同步时间</th>
            </tr>
          </thead>
          <tbody>
            <% records.forEach(r => { %>
              <tr>
                <td class="id-cell">#<%= r.id %></td>
                <td><span class="client-cell"><%= r.client_id %></span></td>
                <td class="barcode-cell"><%= r.barcode %></td>
                <td style="color: <%= r.overall_area > 0.4 ? '#dc2626' : '#16a34a' %>; font-weight: 600;"><%= r.overall_area %></td>
                <td><%= r.adhesive_area %></td>
                <td><% if (r.is_valid === 1) { %><span class="badge-pass">✅ 合格</span><% } else { %><span class="badge-fail">🚫 不合格</span><% } %></td>
                <td class="file-cell" title="<%= r.source_file %>"><%= r.source_file %></td>
                <td class="time-cell"><%= r.collected_at || '-' %></td>
                <td class="time-cell"><%= r.synced_at || '-' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>来源</th>
              <th>条码</th>
              <th>产品型号</th>
              <th>通道</th>
              <th>芯片温度</th>
              <th>温差</th>
              <th>热阻</th>
              <th>结果</th>
              <th>判定</th>
              <th>采集时间</th>
            </tr>
          </thead>
          <tbody>
            <% records.forEach(r => { %>
              <tr>
                <td class="id-cell">#<%= r.id %></td>
                <td><span class="client-cell"><%= r.client_id %></span></td>
                <td class="barcode-cell"><%= r.barcode %></td>
                <td><%= r.product_name || '-' %></td>
                <td><%= r.channel || '-' %></td>
                <td><%= r.chip_temp %></td>
                <td><%= r.temp_diff %></td>
                <td><%= r.thermal_resistance %></td>
                <td><%= r.result || '-' %></td>
                <td><% if (r.is_valid === 1) { %><span class="badge-pass">合格</span><% } else { %><span class="badge-fail">不合格</span><% } %></td>
                <td class="time-cell"><%= r.collected_at || '-' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>

      <!-- 分页 -->
      <% if (records.length > 0) { %>
        <div class="pagination">
          <div>共 <strong><%= total %></strong> 条记录，第 <strong><%= page %></strong> / <strong><%= totalPages %></strong> 页</div>
          <div class="page-nav">
            <a href="/?tab=<%= tab %>&page=<%= page - 1 %>&search=<%= search %>&token=<%= token %>" class="<%= page <= 1 ? 'disabled' : '' %>">← 上一页</a>
            <a href="/?tab=<%= tab %>&page=<%= page + 1 %>&search=<%= search %>&token=<%= token %>" class="<%= page >= totalPages ? 'disabled' : '' %>">下一页 →</a>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
