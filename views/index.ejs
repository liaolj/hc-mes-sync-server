<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>合创 MES 数据同步中心</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', sans-serif;
      background: #f0f2f5;
      color: #2c3e50;
      min-height: 100vh;
    }

    /* 顶部导航 */
    .navbar {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      color: white;
      padding: 16px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    }
    .navbar h1 {
      font-size: 18px;
      font-weight: 600;
      letter-spacing: 1px;
    }
    .navbar .stats {
      display: flex;
      gap: 24px;
      font-size: 13px;
      opacity: 0.85;
    }
    .navbar .stats span { font-weight: 600; color: #4fc3f7; }
    .navbar-right {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    /* 主体 */
    .main { max-width: 1400px; margin: 0 auto; padding: 24px; }

    /* Tab 栏 */
    .tabs {
      display: flex;
      gap: 4px;
      margin-bottom: 20px;
      background: white;
      border-radius: 10px;
      padding: 6px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .tab {
      flex: 1;
      text-align: center;
      padding: 10px 20px;
      border-radius: 8px;
      text-decoration: none;
      color: #666;
      font-weight: 500;
      font-size: 14px;
      transition: all 0.2s;
    }
    .tab:hover { background: #f5f7fa; color: #333; }
    .tab.active {
      background: #3b82f6;
      color: white;
      box-shadow: 0 2px 8px rgba(59,130,246,0.3);
    }

    /* 搜索栏与筛选区 */
    .filter-bar {
      display: flex;
      gap: 12px;
      margin-bottom: 20px;
      align-items: center;
      flex-wrap: wrap;
    }
    .filter-bar select {
      padding: 10px 14px;
      border: 1px solid #dfe6e9;
      border-radius: 8px;
      font-size: 14px;
      outline: none;
      background: white;
      min-width: 220px;
      cursor: pointer;
      transition: border-color 0.2s;
      color: #334155;
    }
    .filter-bar select:focus { border-color: #3b82f6; }
    .filter-bar input {
      flex: 1;
      padding: 10px 16px;
      border: 1px solid #dfe6e9;
      border-radius: 8px;
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s;
      min-width: 200px;
    }
    .filter-bar input:focus { border-color: #3b82f6; }
    .filter-bar button {
      padding: 10px 24px;
      background: #3b82f6;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      cursor: pointer;
      font-weight: 500;
      transition: background 0.2s;
    }
    .filter-bar button:hover { background: #2563eb; }
    .btn-clear-filter {
      padding: 10px 18px;
      background: #f1f5f9;
      color: #475569;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      cursor: pointer;
      font-weight: 500;
      transition: all 0.2s;
    }
    .btn-clear-filter:hover { background: #e2e8f0; }

    /* 表格 */
    .table-card {
      background: white;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 1px 6px rgba(0, 0, 0, 0.06);
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    thead th {
      background: #f8fafc;
      padding: 12px 14px;
      text-align: left;
      font-weight: 600;
      color: #475569;
      border-bottom: 2px solid #e2e8f0;
      white-space: nowrap;
    }
    tbody td {
      padding: 10px 14px;
      border-bottom: 1px solid #f1f5f9;
      white-space: nowrap;
    }
    tbody tr:hover { background: #f8fafc; }
    .badge-pass {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 12px;
      font-weight: 600;
      background: #dcfce7;
      color: #16a34a;
    }
    .badge-fail {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 12px;
      font-weight: 600;
      background: #fef2f2;
      color: #dc2626;
    }
    .id-cell { color: #94a3b8; font-family: monospace; }
    .barcode-cell { font-weight: 600; font-family: monospace; }
    .file-cell { color: #64748b; font-size: 12px; max-width: 180px; overflow: hidden; text-overflow: ellipsis; }
    .time-cell { color: #94a3b8; font-size: 12px; }
    .client-cell {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 2px 8px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 500;
      background: #ede9fe;
      color: #7c3aed;
      max-width: 200px;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .client-alias {
      font-weight: 700;
      color: #5b21b6;
    }
    .client-mac {
      opacity: 0.7;
      font-size: 10px;
      font-family: monospace;
    }

    /* 分页 */
    .pagination {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 20px;
      font-size: 13px;
      color: #64748b;
      background: white;
      border-top: 1px solid #f1f5f9;
    }
    .pagination a {
      padding: 8px 18px;
      background: #f1f5f9;
      color: #334155;
      text-decoration: none;
      border-radius: 6px;
      font-weight: 500;
      transition: background 0.2s;
    }
    .pagination a:hover { background: #e2e8f0; }
    .pagination a.disabled { opacity: 0.4; pointer-events: none; }
    .page-nav { display: flex; gap: 8px; align-items: center; }

    .empty {
      padding: 60px 20px;
      text-align: center;
      color: #94a3b8;
      font-size: 14px;
    }

    /* 导航栏按钮通用 */
    .navbar-btn {
      padding: 8px 18px;
      border-radius: 8px;
      font-size: 13px;
      cursor: pointer;
      font-weight: 500;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 6px;
      border: 1px solid;
    }

    /* 客户端管理按钮 */
    .btn-clients {
      background: rgba(79, 195, 247, 0.15);
      color: #b3e5fc;
      border-color: rgba(79, 195, 247, 0.3);
    }
    .btn-clients:hover {
      background: rgba(79, 195, 247, 0.3);
      color: #e1f5fe;
      border-color: rgba(79, 195, 247, 0.5);
    }

    /* 重置按钮 */
    .btn-reset {
      background: rgba(239, 68, 68, 0.15);
      color: #fca5a5;
      border-color: rgba(239, 68, 68, 0.3);
    }
    .btn-reset:hover {
      background: rgba(239, 68, 68, 0.3);
      color: #fef2f2;
      border-color: rgba(239, 68, 68, 0.5);
    }

    /* 模态对话框 */
    .modal-overlay {
      display: none;
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(0, 0, 0, 0.5);
      z-index: 1000;
      justify-content: center;
      align-items: center;
      backdrop-filter: blur(4px);
    }
    .modal-overlay.active { display: flex; }
    .modal {
      background: white;
      border-radius: 16px;
      padding: 32px;
      width: 520px;
      max-width: 90vw;
      max-height: 80vh;
      overflow-y: auto;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
      animation: modalIn 0.2s ease-out;
    }
    @keyframes modalIn {
      from { opacity: 0; transform: scale(0.95) translateY(10px); }
      to { opacity: 1; transform: scale(1) translateY(0); }
    }
    .modal h2 {
      font-size: 18px;
      margin-bottom: 16px;
      color: #1e293b;
    }
    .modal .warning {
      background: #fef2f2;
      border: 1px solid #fecaca;
      border-radius: 10px;
      padding: 12px 16px;
      margin: 16px 0;
      color: #991b1b;
      font-size: 13px;
      line-height: 1.5;
    }
    .modal .options {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin: 16px 0 24px;
    }
    .modal .option-btn {
      padding: 12px 16px;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      background: #f8fafc;
      cursor: pointer;
      font-size: 14px;
      text-align: left;
      transition: all 0.15s;
      color: #334155;
    }
    .modal .option-btn:hover {
      border-color: #3b82f6;
      background: #eff6ff;
    }
    .modal .option-btn.selected {
      border-color: #ef4444;
      background: #fef2f2;
      color: #991b1b;
      font-weight: 600;
    }
    .modal-actions {
      display: flex;
      gap: 12px;
      justify-content: flex-end;
      margin-top: 20px;
    }
    .modal-actions button {
      padding: 10px 24px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s;
      border: none;
    }
    .btn-cancel {
      background: #f1f5f9;
      color: #475569;
    }
    .btn-cancel:hover { background: #e2e8f0; }
    .btn-confirm-reset {
      background: #ef4444;
      color: white;
      opacity: 0.5;
      pointer-events: none;
    }
    .btn-confirm-reset.enabled {
      opacity: 1;
      pointer-events: auto;
    }
    .btn-confirm-reset.enabled:hover { background: #dc2626; }

    /* 客户端管理弹窗样式 */
    .client-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-top: 12px;
    }
    .client-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      transition: all 0.15s;
    }
    .client-item:hover {
      border-color: #c7d2fe;
      background: #f5f3ff;
    }
    .client-info {
      flex: 1;
      min-width: 0;
    }
    .client-info .mac {
      font-family: monospace;
      font-size: 13px;
      color: #475569;
      font-weight: 600;
    }
    .client-info .record-hint {
      font-size: 11px;
      color: #94a3b8;
      margin-top: 2px;
    }
    .alias-input {
      width: 140px;
      padding: 6px 10px;
      border: 1px solid #dfe6e9;
      border-radius: 6px;
      font-size: 13px;
      outline: none;
      transition: border-color 0.2s;
    }
    .alias-input:focus { border-color: #7c3aed; }
    .btn-save-alias {
      padding: 6px 14px;
      background: #7c3aed;
      color: white;
      border: none;
      border-radius: 6px;
      font-size: 12px;
      cursor: pointer;
      font-weight: 500;
      transition: background 0.2s;
      white-space: nowrap;
    }
    .btn-save-alias:hover { background: #6d28d9; }
    .btn-save-alias:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .alias-saved {
      color: #16a34a;
      font-size: 12px;
      font-weight: 500;
      animation: fadeIn 0.2s;
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    .client-empty {
      text-align: center;
      padding: 32px;
      color: #94a3b8;
      font-size: 14px;
    }

    /* 版本徽章 */
    .version-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      margin-left: 12px;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      font-family: 'SF Mono', 'Fira Code', monospace;
      background: rgba(79, 195, 247, 0.15);
      color: #4fc3f7;
      border: 1px solid rgba(79, 195, 247, 0.25);
      letter-spacing: 0.5px;
      vertical-align: middle;
    }
    .version-badge::before {
      content: '';
      display: inline-block;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #4fc3f7;
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    /* 页脚 */
    .app-footer {
      max-width: 1400px;
      margin: 24px auto 0;
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 12px;
      color: #94a3b8;
    }
    .footer-version {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .footer-version-tag {
      padding: 2px 8px;
      border-radius: 4px;
      background: #e2e8f0;
      color: #475569;
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-weight: 600;
      font-size: 11px;
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <h1>📡 合创 MES 数据同步中心 <span class="version-badge">v<%= version %></span></h1>
    <div class="navbar-right">
      <div class="stats">
        平坦度数据: <span><%= flatnessTotal %></span> 条 &nbsp;|&nbsp;
        热阻数据: <span><%= thermalTotal %></span> 条
      </div>
      <button class="navbar-btn btn-clients" onclick="openClientModal()">🏷️ 管理客户端</button>
      <button class="navbar-btn btn-reset" onclick="openResetModal()">🗑️ 重置数据库</button>
    </div>
  </nav>

  <div class="main">
    <!-- Tab 切换 -->
    <div class="tabs">
      <a class="tab <%= tab === 'flatness' ? 'active' : '' %>" href="/?tab=flatness&token=<%= token %><%= clientId ? '&client_id=' + encodeURIComponent(clientId) : '' %>">
        📐 平坦度数据 (<%= flatnessTotal %>)
      </a>
      <a class="tab <%= tab === 'thermal' ? 'active' : '' %>" href="/?tab=thermal&token=<%= token %><%= clientId ? '&client_id=' + encodeURIComponent(clientId) : '' %>">
        🌡️ 热阻数据 (<%= thermalTotal %>)
      </a>
    </div>

    <!-- 筛选栏 -->
    <form class="filter-bar" method="GET" action="/">
      <input type="hidden" name="tab" value="<%= tab %>">
      <input type="hidden" name="token" value="<%= token %>">
      <select name="client_id" onchange="this.form.submit()">
        <option value="">全部客户端</option>
        <% clients.forEach(c => { %>
          <option value="<%= c.client_id %>" <%= clientId === c.client_id ? 'selected' : '' %>>
            <%= c.alias ? c.alias + '（' + c.client_id + '）' : c.client_id %>
          </option>
        <% }); %>
      </select>
      <input type="text" name="search" value="<%= search %>" placeholder="输入条码关键字搜索...">
      <button type="submit">🔍 搜索</button>
      <% if (clientId || search) { %>
        <a href="/?tab=<%= tab %>&token=<%= token %>" class="btn-clear-filter">✕ 清除筛选</a>
      <% } %>
    </form>

    <!-- 数据表格 -->
    <div class="table-card">
      <% if (records.length === 0) { %>
        <div class="empty">📭 暂无数据记录</div>
      <% } else if (tab === 'flatness') { %>
        <table>
          <thead>
            <tr>
              <th>数据标号</th>
              <th>条形码</th>
              <th>整体平坦度</th>
              <th>背胶平坦度</th>
              <th>是否合格</th>
              <th>采集时间</th>
              <th>来源客户端</th>
              <th>源文件</th>
              <th>同步时间</th>
            </tr>
          </thead>
          <tbody>
            <% records.forEach(r => { %>
              <tr>
                <td class="id-cell">#<%= r.id %></td>
                <td class="barcode-cell"><%= r.barcode %></td>
                <td style="color: <%= r.overall_area > 0.4 ? '#dc2626' : '#16a34a' %>; font-weight: 600;"><%= r.overall_area %></td>
                <td><%= r.adhesive_area %></td>
                <td><% if (r.is_valid === 1) { %><span class="badge-pass">✅ 合格</span><% } else { %><span class="badge-fail">🚫 不合格</span><% } %></td>
                <td class="time-cell"><%= r.collected_at || '-' %></td>
                <td>
                  <span class="client-cell" title="<%= r.client_id %>">
                    <% if (aliasMap[r.client_id]) { %>
                      <span class="client-alias"><%= aliasMap[r.client_id] %></span>
                      <span class="client-mac">(<%= r.client_id %>)</span>
                    <% } else { %>
                      <%= r.client_id %>
                    <% } %>
                  </span>
                </td>
                <td class="file-cell" title="<%= r.source_file %>"><%= r.source_file %></td>
                <td class="time-cell"><%= r.synced_at || '-' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>来源</th>
              <th>条码</th>
              <th>产品型号</th>
              <th>通道</th>
              <th>芯片温度</th>
              <th>温差</th>
              <th>热阻</th>
              <th>结果</th>
              <th>判定</th>
              <th>采集时间</th>
            </tr>
          </thead>
          <tbody>
            <% records.forEach(r => { %>
              <tr>
                <td class="id-cell">#<%= r.id %></td>
                <td>
                  <span class="client-cell" title="<%= r.client_id %>">
                    <% if (aliasMap[r.client_id]) { %>
                      <span class="client-alias"><%= aliasMap[r.client_id] %></span>
                      <span class="client-mac">(<%= r.client_id %>)</span>
                    <% } else { %>
                      <%= r.client_id %>
                    <% } %>
                  </span>
                </td>
                <td class="barcode-cell"><%= r.barcode %></td>
                <td><%= r.product_name || '-' %></td>
                <td><%= r.channel || '-' %></td>
                <td><%= r.chip_temp %></td>
                <td><%= r.temp_diff %></td>
                <td><%= r.thermal_resistance %></td>
                <td><%= r.result || '-' %></td>
                <td><% if (r.is_valid === 1) { %><span class="badge-pass">合格</span><% } else { %><span class="badge-fail">不合格</span><% } %></td>
                <td class="time-cell"><%= r.collected_at || '-' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>

      <!-- 分页 -->
      <% if (records.length > 0) { %>
        <div class="pagination">
          <div>共 <strong><%= total %></strong> 条记录，第 <strong><%= page %></strong> / <strong><%= totalPages %></strong> 页</div>
          <div class="page-nav">
            <a href="/?tab=<%= tab %>&page=<%= page - 1 %>&search=<%= search %>&client_id=<%= clientId %>&token=<%= token %>" class="<%= page <= 1 ? 'disabled' : '' %>">← 上一页</a>
            <a href="/?tab=<%= tab %>&page=<%= page + 1 %>&search=<%= search %>&client_id=<%= clientId %>&token=<%= token %>" class="<%= page >= totalPages ? 'disabled' : '' %>">下一页 →</a>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- 页脚版本信息 -->
  <footer class="app-footer">
    <div class="footer-version">
      <span>合创 MES 数据同步服务器</span>
      <span class="footer-version-tag">v<%= version %></span>
    </div>
    <div>© 2024 合创科技</div>
  </footer>

  <!-- 客户端管理模态对话框 -->
  <div class="modal-overlay" id="clientModal">
    <div class="modal">
      <h2>🏷️ 客户端管理</h2>
      <p style="font-size: 13px; color: #64748b; margin-bottom: 16px;">为 MAC 地址设置备注名，方便识别不同设备。</p>
      <div class="client-list" id="clientList">
        <% if (clients.length === 0) { %>
          <div class="client-empty">暂无已连接的客户端</div>
        <% } else { %>
          <% clients.forEach(c => { %>
            <div class="client-item" data-client-id="<%= c.client_id %>">
              <div class="client-info">
                <div class="mac"><%= c.client_id %></div>
              </div>
              <input type="text"
                     class="alias-input"
                     value="<%= c.alias %>"
                     placeholder="输入备注名..."
                     data-client-id="<%= c.client_id %>"
                     data-original="<%= c.alias %>">
              <button class="btn-save-alias" onclick="saveAlias(this)" data-client-id="<%= c.client_id %>">保存</button>
            </div>
          <% }); %>
        <% } %>
      </div>
      <div class="modal-actions">
        <button class="btn-cancel" onclick="closeClientModal()">关闭</button>
      </div>
    </div>
  </div>

  <!-- 重置数据库模态对话框 -->
  <div class="modal-overlay" id="resetModal">
    <div class="modal">
      <h2>⚠️ 重置数据库</h2>
      <div class="warning">
        <strong>警告：此操作不可撤销！</strong><br>
        所选数据将被永久删除，请确认后再操作。
      </div>
      <p style="font-size:14px; color:#475569; margin-bottom:8px;">请选择要清空的数据类型：</p>
      <div class="options">
        <button class="option-btn" data-target="all" onclick="selectResetTarget(this)">
          🗃️ 清空所有数据（平坦度 + 热阻）
        </button>
        <button class="option-btn" data-target="flatness" onclick="selectResetTarget(this)">
          📐 仅清空平坦度数据（<%= flatnessTotal %> 条）
        </button>
        <button class="option-btn" data-target="thermal" onclick="selectResetTarget(this)">
          🌡️ 仅清空热阻数据（<%= thermalTotal %> 条）
        </button>
      </div>
      <div class="modal-actions">
        <button class="btn-cancel" onclick="closeResetModal()">取消</button>
        <button class="btn-confirm-reset" id="confirmResetBtn" onclick="executeReset()">确认重置</button>
      </div>
    </div>
  </div>

  <script>
    const token = '<%= token %>';

    // ========== 客户端管理弹窗 ==========
    function openClientModal() {
      document.getElementById('clientModal').classList.add('active');
    }
    function closeClientModal() {
      document.getElementById('clientModal').classList.remove('active');
    }
    // 点击遮罩关闭
    document.getElementById('clientModal').addEventListener('click', function(e) {
      if (e.target === this) closeClientModal();
    });

    // 保存备注名
    async function saveAlias(btn) {
      const clientId = btn.dataset.clientId;
      const input = btn.parentElement.querySelector('.alias-input');
      const alias = input.value.trim();

      btn.disabled = true;
      btn.textContent = '保存中...';

      try {
        const res = await fetch(`/api/clients/${encodeURIComponent(clientId)}/alias?token=${encodeURIComponent(token)}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ alias }),
        });
        const data = await res.json();
        if (data.success) {
          btn.textContent = '✓ 已保存';
          btn.style.background = '#16a34a';
          input.dataset.original = alias;
          // 1.5 秒后恢复
          setTimeout(() => {
            btn.textContent = '保存';
            btn.style.background = '';
            btn.disabled = false;
          }, 1500);
          // 刷新页面以更新表格和筛选器中的显示
          setTimeout(() => location.reload(), 1600);
        } else {
          alert('保存失败：' + (data.error || '未知错误'));
          btn.textContent = '保存';
          btn.disabled = false;
        }
      } catch (err) {
        alert('请求失败：' + err.message);
        btn.textContent = '保存';
        btn.disabled = false;
      }
    }

    // ========== 重置数据库弹窗 ==========
    let selectedTarget = null;

    function openResetModal() {
      selectedTarget = null;
      document.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
      document.getElementById('confirmResetBtn').classList.remove('enabled');
      document.getElementById('resetModal').classList.add('active');
    }

    function closeResetModal() {
      document.getElementById('resetModal').classList.remove('active');
    }

    function selectResetTarget(btn) {
      document.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      selectedTarget = btn.dataset.target;
      document.getElementById('confirmResetBtn').classList.add('enabled');
    }

    // 点击遮罩层关闭
    document.getElementById('resetModal').addEventListener('click', function(e) {
      if (e.target === this) closeResetModal();
    });

    async function executeReset() {
      if (!selectedTarget) return;

      const targetLabels = { all: '所有数据', flatness: '平坦度数据', thermal: '热阻数据' };
      if (!confirm(`最后确认：确定要永久删除【${targetLabels[selectedTarget]}】吗？`)) return;

      try {
        const res = await fetch('/api/reset?token=' + encodeURIComponent(token), {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ target: selectedTarget }),
        });
        const data = await res.json();
        if (data.success) {
          alert(`重置成功！共删除 ${data.deleted.total} 条记录。`);
          location.reload();
        } else {
          alert('重置失败：' + (data.error || '未知错误'));
        }
      } catch (err) {
        alert('请求失败：' + err.message);
      }
    }
  </script>
</body>
</html>
